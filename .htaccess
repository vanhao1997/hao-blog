# BEGIN Cache & Compression
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml application/xml
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|png|jpg|jpeg|webp|svg|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(html)$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>
</IfModule>
# END Cache & Compression

# Block sensitive files
<FilesMatch "\.(sql|log|bak|env|ini)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Custom 404
ErrorDocument 404 /404.html

# Rewrite rules
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Pretty URLs — specific aliases
RewriteRule ^blog$ /blog.html [L]
RewriteRule ^gioi-thieu$ /about.html [L]
RewriteRule ^lien-he$ /contact.html [L]
RewriteRule ^toolkit$ /toolkit/index.html [L]

# Generic .html extension removal — works for ALL directories
# e.g. /admin/login → /admin/login.html, /toolkit/banner_tool → /toolkit/banner_tool.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Blog post pretty URLs: /blog/my-post-slug → post.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^blog/(.+)$ /post.html [L]
